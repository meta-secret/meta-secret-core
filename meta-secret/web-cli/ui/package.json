{
  "name": "meta-secret-ui-vue",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --port 5050 --host 127.0.0.1",
    "test:unit": "vitest --environment jsdom",
    "test:e2e": "env -u ELECTRON_RUN_AS_NODE start-server-and-test preview http://127.0.0.1:5050/ 'cypress open'",
    "test:e2e:ci": "npm run build && env -u ELECTRON_RUN_AS_NODE start-server-and-test preview http://127.0.0.1:5050/ 'cypress run'",
    "typecheck": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "postbuild": "cp dist/index.html dist/404.html"
  },
  "dependencies": {
    "@headlessui/vue": "1.7.23",
    "@heroicons/vue": "2.2.0",
    "meta-secret-web-cli": "file:./pkg",
    "pinia": "3.0.2",
    "qr-code-styling": "1.9.2",
    "serve": "14.2.4",
    "vite-plugin-wasm": "3.4.1",
    "vue": "3.5.13",
    "vue-github-button": "3.1.3",
    "vue-router": "4.5.1",
    "wasm-pack": "0.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jsdom": "21.1.7",
    "@types/node": "22.15.3",
    "@vitejs/plugin-vue": "5.2.3",
    "@vitejs/plugin-vue-jsx": "4.1.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.7.0",
    "autoprefixer": "10.4.21",
    "cypress": "14.3.2",
    "eslint": "^9.39.4",
    "eslint-plugin-cypress": "3.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "26.1.0",
    "postcss": "8.5.3",
    "prettier": "3.5.3",
    "qr-scanner": "1.4.2",
    "start-server-and-test": "2.0.11",
    "tailwindcss": "3.4.10",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.61.1",
    "vite": "6.3.4",
    "vite-plugin-wasm": "3.4.1",
    "vite-plugin-wasm-pack": "0.1.12",
    "vitest": "3.1.2",
    "vue-tsc": "2.2.10",
    "webpack": "5.99.7",
    "webpack-cli": "6.0.1"
  }
}
